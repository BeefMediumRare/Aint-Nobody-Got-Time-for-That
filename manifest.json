{
  "manifest_version": 3,
  "name": "Ain't Nobody Got Time for That",
  "version": "1.0.0",
  "description": "Script YouTube playback speed against video timestamps.",
  "browser_specific_settings": {
    "gecko": {
      "id": "aint-nobody-got-time-for-that@beefmediumrare",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "icons": {
    "48": "icons/icon.svg",
    "96": "icons/icon.svg"
  },
  "permissions": ["activeTab", "storage", "unlimitedStorage"],
  "optional_host_permissions": [
    "https://api.github.com/*",
    "https://raw.githubusercontent.com/*"
  ],
  "action": {
    "default_title": "Ain't Nobody Got Time for That",
    "default_popup": "src/popup.html",
    "default_icon": "icons/icon.svg"
  },
  "options_ui": {
    "page": "src/options.html",
    "open_in_tab": true
  },
  "background": {
    "scripts": ["src/theme.js", "src/parser.js", "src/storage.js", "src/tracks.js", "src/background.js"]
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["src/theme.js", "src/parser.js", "src/storage.js", "src/video-id.js", "src/content.js", "src/timeline.js", "src/author.js"],
      "run_at": "document_idle"
    }
  ]
}
